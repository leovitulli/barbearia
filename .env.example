# San Patricio Barbearia - Environment Variables Example
# Copy this file to .env for local development

# API Configuration (for future backend integration)
# VITE_API_URL=http://localhost:3000/api
# VITE_API_TIMEOUT=30000

# Authentication (for future implementation)
# VITE_JWT_SECRET=your-secret-key-here
# VITE_JWT_EXPIRATION=7d

# File Upload (for future cloud storage)
# VITE_UPLOAD_MAX_SIZE=5242880
# VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
# VITE_CLOUDINARY_API_KEY=your-api-key

# Features Flags
# VITE_ENABLE_NOTIFICATIONS=true
# VITE_ENABLE_ONLINE_BOOKING=false

# Analytics (optional)
# VITE_GA_TRACKING_ID=UA-XXXXXXXXX-X

# Note: This project currently uses mock data in memory.
# These environment variables are examples for future production use.
